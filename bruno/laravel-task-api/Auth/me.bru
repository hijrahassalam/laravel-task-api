meta {
  name: Me
  type: http
  seq: 3
}

get {
  url: {{base_url}}/api/v1/me
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

tests {
  test("should return 200 status", function() {
    expect(res.status).to.equal(200);
  });

  test("should return user object", function() {
    expect(res.body.user).to.exist;
    expect(res.body.user.id).to.exist;
    expect(res.body.user.email).to.exist;
  });
}
